# Supabase Configuration
# IMPORTANT: Never place a service_role key here! Use only the public anon key.
VITE_SUPABASE_URL=https://your-supabase-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key_here

# Temporary Supabase Configuration (Optional)
VITE_TEMP_SUPABASE_URL=https://your-temp-supabase-project.supabase.co
VITE_TEMP_SUPABASE_ANON_KEY=your_temp_supabase_anon_key_here
